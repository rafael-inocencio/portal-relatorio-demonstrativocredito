{
  "name": "demonstrativo-credito",
  "version": "1.0.0",
  "engines": { "node": ">=20" },
  "sapux": ["app/credito"],
  "scripts": {
    "start": "cds-serve",
    "dev"  : "cds watch",
    "build": "cds build --production",
    "test" : "jest --testEnvironment node"
  },
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^3",
    "@sap-cloud-sdk/http-client" : "^3",
    "@sap/cds"                  : "^9",
    "@sap/xssec"                : "^4",
    "express"                   : "^4",
    "fast-xml-parser"           : "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test"         : "latest",
    "@cap-js/sqlite"           : "^2",
    "@sap/cds-dk"              : "^9",
    "@ui5/cli"                 : "^4",
    "cds-plugin-ui5"           : "^0.17.0",
    "jest"                     : "^29",
    "ui5-middleware-simpleproxy": "^3",
    "ui5-task-zipper"          : "^3"
  },
  "jest": {
    "testTimeout": 30000
  },
  "cds": {
    "requires": {
      "auth": {
        "[development]": { "kind": "mocked" },
        "kind": "xsuaa"
      },
      "connectivity": true,
      "destinations": true,
      "html5-runtime": true
    },
    "server": { "cors": true }
  }
}
